{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atelier",
  "version": "0.1.4",
  "identifier": "com.atelier.desktop",
  "build": {
    "frontendDist": "../shell"
  },
  "app": {
    "windows": [
      { "title": "Atelier", "width": 1200, "height": 820, "minWidth": 720, "minHeight": 520, "resizable": true }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns", "icons/icon.ico"],
    "externalBin": [
      "binaries/atelier-launcher",
      "binaries/atelier-backend",
      "binaries/atelier-tools"
    ],
    "resources": ["frontend-dist/**/*"],
    "macOS": {
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {}
}

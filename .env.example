# Copy to .env and fill in. Never commit .env.

# --- NVIDIA NIM (build.nvidia.com) ---
# Get key at https://build.nvidia.com/ -> any model -> "Get API Key"
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Tavily web search ---
# Free tier: https://tavily.com/
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Google OAuth ---
# https://console.cloud.google.com/ -> APIs & Services -> Credentials -> OAuth client (Web)
# Authorized redirect URI: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# Self-serve signup. 1 = any verified Google account is admitted instantly (public
# SaaS mode); inference still requires the user to connect their own OpenRouter
# account, so open signup costs the operator nothing. 0 = invite/approval model,
# where ALLOWED_EMAILS / admin approval gate access.
OPEN_SIGNUP=1

# Comma-separated Google emails pre-approved even when OPEN_SIGNUP=0. Leave empty
# for fully open (OPEN_SIGNUP=1) or admin-approval-only signup.
ALLOWED_EMAILS=

# Email of the admin (gets admin UI access).
ADMIN_EMAIL=bibinkanichukatt@gmail.com

# Per-user disk quota across all project folders, in bytes (default 2 GiB). Enforced
# by the tools sidecar on writes/clones. Tune EXEC_MAX_PROCS / EXEC_MAX_FILE_MB to
# cap a single command's processes / largest file in the shared sandbox.
USER_QUOTA_BYTES=2147483648

# --- AI firewall (LLM Guard sidecar) ---
# The `guard` service scans the user message in (block prompt-injection/jailbreak)
# and the model's answer out (redact leaked API keys/secrets). Models are baked
# into the image at build, so it needs no network and runs read-only.
FIREWALL_ENABLED=1
# Sidecar unreachable → 1 = keep chat up (log loudly), 0 = hard-gate the turn.
FIREWALL_FAIL_OPEN=1
# Prompt-injection block threshold (0–1; higher = fewer false positives).
FIREWALL_INPUT_THRESHOLD=0.85
# Also run a toxicity scanner on user input (off by default — avoids locking out
# normal-but-blunt messages). 1 to enable.
FIREWALL_TOXICITY_INPUT=0
# Phase 2 controls (all default on; "defang, don't block"):
#   TOOL_SCAN — scan web_fetch/web_search/codebase_search results for indirect
#               prompt injection and warn the model (untrusted external content).
#   PII_OUTPUT — redact PII (email/phone/card/SSN/IBAN/crypto/IP) from answers.
#   CODE_SCAN — scan LLM-written/cloned code with CodeShield (insecure patterns).
FIREWALL_TOOL_SCAN=1
FIREWALL_PII_OUTPUT=1
FIREWALL_CODE_SCAN=1
# Phase 3:
#   BUFFER_OUTPUT — withhold the final answer until after the output scan, so a
#                   leaked secret is never visible in-flight. Trade-off: the final
#                   answer appears all-at-once instead of token-by-token.
#   ALIGNMENT_CHECK — after a tool-using turn, an LLM critic audits whether the
#                   agent's actions still serve the request (goal-drift / hijack).
#   ALIGNMENT_BLOCK — withhold the answer on a misalignment (most useful with
#                   BUFFER_OUTPUT on); default off = warn + log only.
#   ALIGNMENT_MODEL — OpenRouter id for the goal-drift critic.
# Per-user overrides for any of these live in the firewall_policy table (admin UI).
FIREWALL_BUFFER_OUTPUT=1
FIREWALL_ALIGNMENT_CHECK=1
FIREWALL_ALIGNMENT_BLOCK=0
ALIGNMENT_MODEL=openai/gpt-oss-20b:free

# --- Session cookie signing ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=replace-me-with-a-long-random-string

# --- Per-user provider keys (OpenRouter OAuth) ---
# Encrypts each user's OpenRouter API key at rest. REQUIRED.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
KEY_ENCRYPTION_KEY=replace-me-with-a-fernet-key
# Set to 1 to let users who haven't connected OpenRouter use the operator's NVIDIA
# key (free trial / keep existing users working). 0 = hard-gate chat until connected.
ENABLE_NIM_FALLBACK=0
# OpenRouter endpoints (defaults are correct; override only for testing).
# OPENROUTER_OAUTH_URL=https://openrouter.ai/auth
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# OPENROUTER_KEY_EXCHANGE_URL=https://openrouter.ai/api/v1/auth/keys

# --- Public URLs ---
# When deploying to a VPS later, change these to your domain (https://...).
PUBLIC_FRONTEND_URL=http://localhost:3000
PUBLIC_BACKEND_URL=http://localhost:8000

# --- Internal service URLs (compose network) ---
TOOLS_URL=http://tools:8001

# --- Project folders ("workspaces") ---
# Host directory bind-mounted into the backend + tools containers as /workspaces.
# Each user gets a subdir; each named project gets a sub-subdir.
WORKSPACES_HOST_DIR=/media/bibintom/4tb/familyai-workspaces

# --- Skills catalog (daily GitHub discovery) ---
# A background job searches public GitHub for Claude-style SKILL.md files once a
# day and fills the browsable "Discover" catalog on the Skills page.
SKILLS_CATALOG_ENABLED=1
# Optional. Works fully WITHOUT a token (unauthenticated GitHub API, ~60 req/hr —
# plenty for once-daily). A token raises the limit to 5000 req/hr. Sent ONLY to
# api.github.com, never to any model endpoint. A classic PAT with no scopes (or a
# fine-grained token with public read) is enough.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# 5-field cron (UTC) for the daily refresh. Default 06:00 UTC.
SKILLS_CATALOG_CRON=0 6 * * *
# Fan-out caps (defaults shown). Lower these to be gentler on the GitHub API.
SKILLS_CATALOG_MAX_REPOS=40
SKILLS_CATALOG_MAX_FILES_PER_REPO=40
# Diversity guard: max skills stored from any single repo, so one mega-repo
# (e.g. a monorepo with 100s of SKILL.md files) can't flood the catalog.
SKILLS_CATALOG_MAX_PER_REPO=5
SKILLS_CATALOG_MAX_SKILLS=400
